[
  {
    "context": "Editor || ProjectPanel || EmptyPane",
    "bindings": {
      "ctrl-e": "project_panel::ToggleFocus",
      "ctrl-f": "file_finder::Toggle",
      "ctrl-b": "tab_switcher::ToggleAll",
      ", f f": "file_finder::Toggle",
      ", f p": "projects::OpenRecent"
    }
  },

  {
    "context": "Editor || Dock",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown"
    }
  },

  {
    "context": "Editor && vim_mode == normal && vim_operator == none && !VimWaiting",
    "bindings": {
      "ctrl-x 1": "pane::CloseOtherItems",
      "ctrl-x 2": "pane::SplitHorizontal",
      "ctrl-x 3": "pane::SplitVertical"
    }
  },

  {
    "context": "Editor && (vim_mode == normal || vim_mode == visual) && !VimWaiting && !menu",
    "bindings": {
      "ctrl-shift-u": "vim::ScrollUp",
      "ctrl-shift-d": "vim::ScrollDown",
      "ctrl-u": ["workspace::SendKeystrokes", "ctrl-shift-u z z"],
      "ctrl-d": ["workspace::SendKeystrokes", "ctrl-shift-d z z"],

      "ctrl-shift-n": "vim::MoveToNextMatch",
      "n": ["workspace::SendKeystrokes", "ctrl-shift-n z z"],

      "z f": "editor::ToggleFold",
      "z a": "editor::FoldAll",
      "z u": "editor::UnfoldAll"
    }
  },

  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      ", e": "workspace::ToggleLeftDock",
      ", t": "workspace::ToggleBottomDock",
      ", b": "tab_switcher::ToggleAll",
      ", p": "outline::Toggle",
      ", z": "workspace::ToggleCenteredLayout",

      "g d": "editor::GoToDefinition",
      "g D": "editor::GoToDefinitionSplit",
      "g i": "editor::GoToImplementation",
      "g I": "editor::GoToImplementationSplit",
      "g t": "editor::GoToTypeDefinition",
      "g T": "editor::GoToTypeDefinitionSplit",
      "g r": "editor::FindAllReferences",
      "shift-k": "editor::Hover",

      "] d": "editor::GoToDiagnostic",
      "[ d": "editor::GoToPreviousDiagnostic",

      "] h": "editor::GoToHunk",
      "[ h": "editor::GoToPreviousHunk",

      "shift-h": "pane::ActivatePreviousItem",
      "shift-l": "pane::ActivateNextItem",
      ", b d": "pane::CloseActiveItem",
      ", b o": "pane::CloseInactiveItems",

      ", f f": "file_finder::Toggle",
      ", f s": "pane::DeploySearch",

      ", s s": "outline::Toggle",
      ", s S": "project_symbols::Toggle",

      ", c a": "editor::ToggleCodeActions",
      ", c r": "editor::Rename",

      ", l f": "editor::Format",
      ", l r": "editor::Rename",
      ", d": "editor::GoToTypeDefinition",
      ", s a": "pane::DeploySearch",
      "ctrl-s": "workspace::Save"
    }
  },

  {
    "context": "Editor && vim_mode == visual && !VimWaiting",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
      "g c": "editor::ToggleComments"
    }
  },

  {
    "context": "Editor && showing_completions",
    "bindings": {
      "enter": null,
      "tab": null,
      "ctrl-y": "editor::ConfirmCompletion"
    }
  },

  {
    "context": "Editor && showing_code_actions",
    "bindings": {
      "enter": null,
      "ctrl-y": "editor::ConfirmCodeAction"
    }
  },

  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "q": "project_panel::ToggleFocus",
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "o": "project_panel::OpenPermanent",
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious"
    }
  }
]
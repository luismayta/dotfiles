#!/usr/bin/env ksh
# -*- coding: utf-8 -*-
# ==============================================================================
# File: base.zsh
# Description: apps module environment variables and configuration
# ==============================================================================
# shellcheck shell=bash
# shellcheck disable=SC2034

export APPS_PACKAGE_NAME=apps
APPS_ARCHITECTURE_NAME="${OSTYPE}-$(uname -m)"
export APPS_ARCHITECTURE_NAME

# ==============================================================================
# IDE Tools
# ==============================================================================
APPS_IDE_TOOLS=(tig meld)

# ==============================================================================
# JetBrains
# ==============================================================================
APPS_JETBRAINS=()

# ==============================================================================
# Communication
# ==============================================================================
APPS_COMMUNICATION=(discord)

# ==============================================================================
# Knowledge
# ==============================================================================
APPS_KNOWLEDGE=()

# ==============================================================================
# DevOps
# ==============================================================================
APPS_DEVOPS=()

# ==============================================================================
# Database Clients
# ==============================================================================
APPS_DATABASE_CLIENTS=()

# ==============================================================================
# Browser
# ==============================================================================
APPS_BROWSER=()

# ==============================================================================
# Android
# ==============================================================================
APPS_ANDROID=(android-studio android-platform-tools)

# ==============================================================================
# Mobile
# ==============================================================================
APPS_MOBILE=()

# ==============================================================================
# VPN Clients
# ==============================================================================
APPS_VPN_CLIENTS=(openvpn)

# ==============================================================================
# Project Management
# ==============================================================================
APPS_PROJECT_MANAGEMENT=(jira-cli)

# ==============================================================================
# Web Apps
# ==============================================================================
APPS_WEB_APPS=()

